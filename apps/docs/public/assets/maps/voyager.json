{
  "version": 8,
  "name": "Namespace Light",
  "sources": {
    "countries": {
      "type": "geojson",
      "data": "/assets/maps/countries.geojson"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": { "background-color": "#f4f4f5" }
    },
    {
      "id": "countries",
      "type": "fill",
      "source": "countries",
      "paint": { "fill-color": "#e4e4e7", "fill-opacity": 1 }
    },
    {
      "id": "country-borders",
      "type": "line",
      "source": "countries",
      "paint": {
        "line-color": "#a1a1aa",
        "line-opacity": 0.8,
        "line-width": 0.75
      }
    }
  ]
}
