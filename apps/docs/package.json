{
  "name": "@thenamespace/docs",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "format": "oxfmt . --write --no-error-on-unmatched-pattern",
    "format:check": "oxfmt . --check --no-error-on-unmatched-pattern",
    "lint": "oxlint src next.config.ts source.config.ts --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint src next.config.ts source.config.ts --fix --no-error-on-unmatched-pattern",
    "migrate:docs": "pnpm migrate:heroui && pnpm sync:pro-docs && pnpm sync:entrypoint-docs && pnpm sync:docs-navigation",
    "migrate:heroui": "node scripts/migrate-heroui-react-docs.mjs",
    "postinstall": "fumadocs-mdx",
    "start": "next start",
    "sync:docs-navigation": "node scripts/organize-component-docs.mjs",
    "sync:entrypoint-docs": "node scripts/add-entrypoint-docs.mjs",
    "sync:pro-docs": "node scripts/sync-heroui-pro-docs.mjs",
    "typecheck": "tsc --noEmit",
    "typegen": "next typegen"
  },
  "dependencies": {
    "@gravity-ui/icons": "2.16.0",
    "@iconify/react": "6.0.2",
    "@internationalized/date": "3.12.2",
    "@react-stately/data": "3.16.1",
    "@tanstack/react-table": "8.21.3",
    "@thenamespace/uikit": "workspace:*",
    "clsx": "2.1.1",
    "fumadocs-core": "16.9.0",
    "fumadocs-mdx": "14.2.2",
    "fumadocs-ui": "16.9.0",
    "lucide-react": "0.562.0",
    "m3-ripple": "1.1.3",
    "next": "16.2.6",
    "next-themes": "0.4.6",
    "react": "catalog:",
    "react-aria-components": "1.18.0",
    "react-dom": "catalog:",
    "tailwind-variants": "3.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.2",
    "@types/mdx": "2.0.14",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "postcss": "8.5.6",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  }
}
