{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "customConditions": ["@repo/source"],
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "isolatedDeclarations": true,
    "module": "Preserve",
    "moduleResolution": "Bundler",
    "noEmitOnError": true,
    "stripInternal": true
  }
}
