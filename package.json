{
  "name": "@thenamespace/source",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "changeset": "changeset",
    "check": "pnpm format:check && pnpm lint && turbo run typecheck build",
    "ci:publish": "turbo run build --filter=@thenamespace/uikit && changeset publish",
    "ci:version": "changeset version",
    "commitlint:edit": "commitlint --strict --edit",
    "commitlint:last": "commitlint --strict --last",
    "commitlint:range": "node scripts/commitlint-range.mjs",
    "dev": "turbo run dev",
    "format": "oxfmt . --write --no-error-on-unmatched-pattern",
    "format:check": "oxfmt . --check --no-error-on-unmatched-pattern",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:check": "pnpm lint",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern",
    "prepare": "lefthook install",
    "sync-theme": "pnpm --filter @thenamespace/storybook sync-theme",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.1",
    "@commitlint/config-conventional": "21.0.1",
    "lefthook": "2.1.9",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@11.7.0"
}
