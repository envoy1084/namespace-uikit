{
  "name": "@thenamespace/uikit",
  "version": "0.1.0",
  "description": "Namespace-themed React components, hooks, utilities, and icons.",
  "keywords": [
    "accessibility",
    "components",
    "design-system",
    "heroui",
    "namespace",
    "react",
    "tailwindcss",
    "typescript",
    "ui-kit"
  ],
  "homepage": "https://github.com/thenamespace/uikit/tree/main/packages/uikit#readme",
  "bugs": {
    "url": "https://github.com/thenamespace/uikit/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thenamespace/uikit.git",
    "directory": "packages/uikit"
  },
  "files": [
    "dist",
    "src"
  ],
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "@thenamespace/source": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./icons": {
      "@thenamespace/source": {
        "types": "./src/icons.ts",
        "import": "./src/icons.ts"
      },
      "types": "./dist/icons.d.mts",
      "import": "./dist/icons.mjs"
    },
    "./hooks": {
      "@thenamespace/source": {
        "types": "./src/hooks.ts",
        "import": "./src/hooks.ts"
      },
      "types": "./dist/hooks.d.mts",
      "import": "./dist/hooks.mjs"
    },
    "./utils": {
      "@thenamespace/source": {
        "types": "./src/utils.ts",
        "import": "./src/utils.ts"
      },
      "types": "./dist/utils.d.mts",
      "import": "./dist/utils.mjs"
    },
    "./number-stepper": {
      "@thenamespace/source": {
        "types": "./src/components/forms/number-stepper/index.ts",
        "import": "./src/components/forms/number-stepper/index.ts"
      },
      "types": "./dist/components/number-stepper.d.mts",
      "import": "./dist/components/number-stepper.mjs"
    },
    "./chart-tooltip": {
      "@thenamespace/source": {
        "types": "./src/components/charts/chart-tooltip/index.ts",
        "import": "./src/components/charts/chart-tooltip/index.ts"
      },
      "types": "./dist/components/chart-tooltip.d.mts",
      "import": "./dist/components/chart-tooltip.mjs"
    },
    "./area-chart": {
      "@thenamespace/source": {
        "types": "./src/components/charts/area-chart/index.ts",
        "import": "./src/components/charts/area-chart/index.ts"
      },
      "types": "./dist/components/area-chart.d.mts",
      "import": "./dist/components/area-chart.mjs"
    },
    "./bar-chart": {
      "@thenamespace/source": {
        "types": "./src/components/charts/bar-chart/index.ts",
        "import": "./src/components/charts/bar-chart/index.ts"
      },
      "types": "./dist/components/bar-chart.d.mts",
      "import": "./dist/components/bar-chart.mjs"
    },
    "./line-chart": {
      "@thenamespace/source": {
        "types": "./src/components/charts/line-chart/index.ts",
        "import": "./src/components/charts/line-chart/index.ts"
      },
      "types": "./dist/components/line-chart.d.mts",
      "import": "./dist/components/line-chart.mjs"
    },
    "./*": {
      "@thenamespace/source": {
        "types": "./src/components/*.ts",
        "import": "./src/components/*.ts"
      },
      "types": "./dist/components/*.d.mts",
      "import": "./dist/components/*.mjs"
    },
    "./styles": {
      "@thenamespace/source": "./src/styles/globals.css",
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./styles.css": {
      "@thenamespace/source": "./src/styles/globals.css",
      "style": "./dist/styles.css",
      "default": "./dist/styles.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown --config tsdown.config.ts",
    "dev": "tsdown --config tsdown.config.ts --watch",
    "format": "oxfmt . --write --no-error-on-unmatched-pattern",
    "format:check": "oxfmt . --check --no-error-on-unmatched-pattern",
    "lint": "oxlint . --no-error-on-unmatched-pattern",
    "lint:fix": "oxlint . --fix --no-error-on-unmatched-pattern",
    "typecheck": "tsc -p tsconfig.json --pretty false"
  },
  "dependencies": {
    "@heroui/react": "^3.2.1",
    "@heroui/styles": "^3.2.1",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@number-flow/react": "0.6.1",
    "react-aria-components": "1.18.0",
    "recharts": "3.9.2"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "react": ">=19.2.7 <20",
    "react-dom": ">=19.2.7 <20",
    "tailwindcss": ">=4.3.2 <5"
  }
}
